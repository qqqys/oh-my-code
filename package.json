{
  "name": "oh-my-code",
  "version": "0.0.0",
  "description": "A repository-aware code agent CLI with Dynamic Workflow orchestration.",
  "type": "module",
  "bin": {
    "oh-my-code": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
